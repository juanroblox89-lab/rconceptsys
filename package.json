{
  "name": "creative-production-os",
  "version": "1.0.0",
  "description": "Sistema Operativo de Producción Creativa - Agencia RConcept",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --open",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); ['coverage','dist','node_modules/.vite'].forEach(p=>fs.existsSync(p)&&fs.rmSync(p,{recursive:true,force:true}));\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "26.1.0",
    "vite": "^5.2.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.110.3"
  }
}
