# Supabase Configuration
# Copy this file to .env.local and fill with your credentials
# Get these from: https://app.supabase.com > Your Project > Settings > API

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLIC-KEY

# Anthropic Claude API (for AI Assistant serverless function)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional server-only aliases used by the AI proxy
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLIC-KEY

# Optional comma-separated cross-origin callers. Same-origin calls need no entry.
ALLOWED_ORIGINS=https://your-production-domain.example
