rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email != null && (request.auth.token.email.toLowerCase() == 'juanroblox89@gmail.com' || request.auth.token.email.toLowerCase() == 'juanroblox89@rohlfing.com');
    }

    // Función auxiliar para verificar si el usuario es administrador
    function isAdmin() {
      return isMasterAdmin() || (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Reglas para Colección Users
    match /users/{userId} {
      // Todos pueden leer perfiles (necesario para asignar tareas)
      allow read: if request.auth != null;
      
      // Creación: Permitir a los admins, o forzar a que sea viewer/no aprobado
      allow create: if request.auth != null 
                    && request.auth.uid == userId 
                    && (
                      isAdmin() || 
                      (request.resource.data.role == 'viewer' && request.resource.data.approved == false)
                    );
      
      // Actualización: Un usuario solo puede actualizar su propio documento y solo ciertos campos, 
      // a menos que sea administrador
      allow update: if isAdmin() || (
                      request.auth != null 
                      && request.auth.uid == userId 
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre', 'phone', 'updatedAt'])
                    );
      
      allow delete: if isAdmin();
    }

    // Reglas para Tareas (Assignments)
    match /assignments/{asgId} {
      allow read: if request.auth != null;
      
      // Permitir crear tareas a admins, O a empleados SOLO si es una corrección
      allow create: if isAdmin() || (
                      request.auth != null && 
                      request.resource.data.id.matches('^corr-.*')
                    );
      
      allow delete: if isAdmin();
      
      // Empleados solo pueden actualizar estado, link y notas de SUS tareas.
      allow update: if isAdmin() || (
                      resource.data.employeeId == request.auth.uid 
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'uploadLink', 'history', 'updatedAt'])
                    );
    }

    // Facturas y Configuración (Admin Only, y empleados para su propia factura)
    match /invoices/{userId} {
      allow read, write: if request.auth != null && (isAdmin() || request.auth.uid == userId);
    }

    match /admin_invoices/{docId} {
      allow read, write: if isAdmin();
    }

    match /rate_cards/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /system_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /chats_limit/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Default para el resto (Clients, Scripts, Assets, SOPs, etc.)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
