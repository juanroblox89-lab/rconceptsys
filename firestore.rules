rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    
    // Fast admin check: uses only the JWT token email — NO get() call needed.
    // This breaks the circular-permission dependency that was causing 403s.
    function isMasterAdmin() {
      return request.auth != null &&
             request.auth.token.email != null &&
             request.auth.token.email.lower().matches('.*juanroblox89.*');
    }

    // Secondary admin check: reads Firestore role only as a fallback.
    // Uses exists() guard to prevent crashing on missing documents.
    function isAdmin() {
      return isMasterAdmin() ||
             (request.auth != null &&
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isApprovedUser() {
      return request.auth != null && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true)
      );
    }

    // ── USERS Collection ──────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Users can always read their own document (no circular dependency)
      // Admins can read all user documents
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Only admins can update/delete other user documents
      // Users can update their own non-sensitive fields
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── INVOICES Collection ───────────────────────────────────
    match /invoices/{invoiceId} {
      allow create: if isApprovedUser() && request.resource.data.employeeId == request.auth.uid;
      allow read, update, delete: if isAdmin() ||
        (isApprovedUser() && resource.data.employeeId == request.auth.uid);
    }

    // ── ADMIN_INVOICES Collection ─────────────────────────────
    match /admin_invoices/{adminInvoiceId} {
      allow read, write: if isAdmin();
    }

    // ── ASSIGNMENTS Collection ───────────────────────────────
    match /assignments/{asgId} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }

    // ── GENERAL Collections ──
    match /clients/{docId} { 
      allow read: if request.auth != null; 
      // Only Admin can create/update/delete client profiles and special fields
      allow write: if isAdmin(); 
    }
    match /formats/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /hooks/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /assets/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /sops/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /references/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /scripts/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /system_rules/{docId} { allow read: if request.auth != null; allow write: if isAdmin(); }

    // ── CHATS and CHATS_LIMIT Collections ────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.userId == request.auth.uid || 
        request.resource.data.userId == request.auth.uid ||
        isMasterAdmin()
      );
    }
    match /chats_limit/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
    }
  }
}
