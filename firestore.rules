rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si el usuario es administrador
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Reglas para Colección Users
    match /users/{userId} {
      // Todos pueden leer perfiles (necesario para asignar tareas)
      allow read: if request.auth != null;
      
      // Creación: Sólo el propio usuario, y OBLIGADO a ser viewer/no aprobado al principio.
      allow create: if request.auth != null 
                    && request.auth.uid == userId 
                    && request.resource.data.role == 'viewer' 
                    && request.resource.data.approved == false;
      
      // Actualización: Sólo administradores pueden cambiar roles o aprobaciones. 
      // El propio usuario solo puede actualizar campos básicos (nombre, teléfono).
      allow update: if isAdmin() || (
                      request.auth.uid == userId 
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre', 'phone', 'updatedAt'])
                    );
      
      allow delete: if isAdmin();
    }

    // Reglas para Tareas (Assignments)
    match /assignments/{asgId} {
      allow read: if request.auth != null;
      
      allow create, delete: if isAdmin();
      
      // Empleados solo pueden actualizar estado, link y notas de SUS tareas.
      allow update: if isAdmin() || (
                      resource.data.employeeId == request.auth.uid 
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'uploadLink', 'history', 'updatedAt'])
                    );
    }

    // Facturas y Configuración (Admin Only)
    match /invoices/{invId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && request.resource.data.employeeId == request.auth.uid);
    }

    match /admin_invoices/{docId} {
      allow read, write: if isAdmin();
    }

    match /rate_cards/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /system_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /chats_limit/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // Default para el resto (Clients, Scripts, Assets, SOPs, etc.)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
