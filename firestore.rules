rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función maestra que identifica a los administradores
    function isAdmin() {
      let email = request.auth.token.email;
      return request.auth != null && (
        email == 'juanroblox89@gmail.com' || 
        email == 'juanroblox89@rohlfing.com' ||
        email == 'samuelrohlfing49@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    match /admin_invoices/{docId} {
      allow read, write: if isAdmin();
    }
    match /system_config/{docId} {
      allow read, write: if isAdmin();
    }
    match /roles/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /clients/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /sops/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      // Admins can do anything. Users can create their own profile, and update their own data but CANNOT escalate privileges.
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'allowedClients', 'marketingVisits']));
      allow delete: if isAdmin();
    }

    match /chats/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /invoices/{docId} {
      allow read, write: if request.auth != null; // Employees manage their own invoices
    }

    // Para tareas, assets, y otros elementos operativos del día a día, permitimos lectura/escritura a miembros
    match /assignments/{docId} {
      allow read, write: if request.auth != null;
    }
    match /assets/{docId} {
      allow read, write: if request.auth != null;
    }
    match /visits/{docId} {
      allow read, write: if request.auth != null;
    }
    match /sop_submissions/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
