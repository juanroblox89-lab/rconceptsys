rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    
    // Fast admin check: uses only the JWT token email — NO get() call needed.
    // This breaks the circular-permission dependency that was causing 403s.
    function isMasterAdmin() {
      return request.auth != null &&
             request.auth.token.email != null &&
             request.auth.token.email.lower().matches('.*juanroblox89.*');
    }

    // Secondary admin check: reads Firestore role only as a fallback.
    // Uses exists() guard to prevent crashing on missing documents.
    function isAdmin() {
      return isMasterAdmin() ||
             (request.auth != null &&
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isApprovedUser() {
      return request.auth != null && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true)
      );
    }

    // ── USERS Collection ──────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // All authenticated team members can read user profiles to list workers and assignments
      allow read: if request.auth != null;
      
      // Only admins or the user themselves can update their profile. Only admins can delete.
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── INVOICES Collection ───────────────────────────────────
    match /invoices/{invoiceId} {
      // Standard approved employees can create/update their own invoice report, keeping their own employeeId
      allow create, update: if isApprovedUser() && request.resource.data.employeeId == request.auth.uid && (invoiceId == 'emp-inv-' + request.auth.uid);
      // Employees and admins can read/delete. Safe for non-existent reads.
      allow read, delete: if isAdmin() || (isApprovedUser() && (resource == null || resource.data.employeeId == request.auth.uid || invoiceId == 'emp-inv-' + request.auth.uid));
    }

    // ── ADMIN_INVOICES Collection ─────────────────────────────
    match /admin_invoices/{adminInvoiceId} {
      // Approved standard users can read their official consolidations. Safe for non-existent reads.
      allow read: if isAdmin() || (isApprovedUser() && (resource == null || resource.data.employeeId == request.auth.uid || adminInvoiceId == 'adm-inv-' + request.auth.uid));
      allow write: if isAdmin();
    }

    // ── ASSIGNMENTS Collection ───────────────────────────────
    match /assignments/{asgId} {
      allow read: if isApprovedUser();
      allow create: if isAdmin();
      // Approved workers can update their own assignments (e.g. status)
      allow update: if isAdmin() || (isApprovedUser() && (resource != null && resource.data.employeeId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // ── GENERAL Collections ──
    match /clients/{docId} { 
      allow read: if isApprovedUser(); 
      // Only Admin can create/update/delete client profiles and special fields
      allow write: if isAdmin(); 
    }
    match /formats/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /hooks/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /assets/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /sops/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /references/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /scripts/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /system_rules/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /roles/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /metrics/{docId} { allow read: if isApprovedUser(); allow write: if isAdmin(); }
    match /sop_submissions/{docId} {
      allow read: if isApprovedUser() && (isAdmin() || resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isApprovedUser() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    // ── CHATS and CHATS_LIMIT Collections ────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.userId == request.auth.uid || 
        request.resource.data.userId == request.auth.uid ||
        isMasterAdmin()
      );
    }
    match /chats_limit/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
    }
  }
}
